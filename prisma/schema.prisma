generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String                @id @default(uuid())
  name                 String
  email                String?
  phone                String?
  industry             String?
  currency             String?
  address              String?
  city                 String?
  country              String?
  logoUrl              String?
  plan                 Plan                  @default(FREE)
  status               OrgStatus             @default(ACTIVE)
  isSetupComplete      Boolean               @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customers            Customer[]
  expenses             Expense[]
  files                File[]
  invoices             Invoice[]
  payments             Payment[]
  products             Product[]
  quotations           Quotation[]
  subscriptionPayments SubscriptionPayment[]
  users                User[]
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  passwordHash   String
  organizationId String?
  role           Role          @default(ADMIN)
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])

  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingConfig {
  id              String   @id @default(uuid())
  monthlyPriceUsd Float    @default(5)
  trialDays       Int      @default(14)
  createdAt       DateTime @default(now())
}



model SubscriptionPayment {
  id              String        @id @default(uuid())
  organizationId  String
  amount          Float
  currency        String        @default("USD")

  phoneNumber     String
  reference       String        @unique

  provider        PaymentProvider @default(ECOCASH)

  status          PaymentStatus @default(PENDING)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  processedAt     DateTime?
  processedBy     String?       // admin user id (optional audit)

  notes           String?

  organization    Organization  @relation(fields: [organizationId], references: [id])
}

model Customer {
  id             String       @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

 deletedAt      DateTime?    // ✅ ADD THIS

  organization   Organization @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  quotations     Quotation[]
}

model Product {
  id             String          @id @default(uuid())
  name           String
  price          Float
  cost           Float
  stock          Int             @default(0)
  type           String          @default("Product")
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoiceItems   InvoiceItem[]
  organization   Organization    @relation(fields: [organizationId], references: [id])
  quotationItems QuotationItem[]
  stockMovements StockMovement[]
}

model StockMovement {
  id             String            @id @default(uuid())
  productId      String
  organizationId String
  type           StockMovementType
  quantity       Int
  reason         String?
  createdAt      DateTime          @default(now())
  product        Product           @relation(fields: [productId], references: [id])
}

model Quotation {
  id              String          @id @default(uuid())
  quotationNumber String          @unique
  customerId      String
  organizationId  String
  status          QuotationStatus @default(DRAFT)
  total           Float           @default(0)
  validUntil      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customer        Customer        @relation(fields: [customerId], references: [id])
  organization    Organization    @relation(fields: [organizationId], references: [id])
  items           QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  productId   String?
  quantity    Int
  price       Float
  total       Float
  name        String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quotation   Quotation @relation(fields: [quotationId], references: [id])
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  customerId     String
  organizationId String
  status         InvoiceStatus @default(PENDING)
  total          Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer      @relation(fields: [customerId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
  items          InvoiceItem[]
  payments       Payment[]
}

model InvoiceItem {
  id        String   @id @default(uuid())
  invoiceId String
  productId String?
  quantity  Int
  price     Float
  total     Float
  name      String?
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  product   Product? @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Expense {
  id             String   @id @default(uuid())
  expenseNumber  String   @unique
  title          String
  category       String
  amount         Float
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  reference      String?
  invoiceId      String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
}

model File {
  id             String       @id @default(uuid())
  url            String
  type           String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

enum Role {
  ADMIN
  STAFF
}

enum Plan {
  FREE
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum PaymentMethod {
  ECOCASH
  CASH
  CARD
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentProvider {
  ECOCASH
  ONEMONEY
  BANK
}
